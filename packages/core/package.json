{
  "name": "@luma/core",
  "type": "module",
  "version": "0.0.0",
  "description": "Luma lightweight Vue admin core components and services.",
  "license": "MIT",
  "keywords": [
    "luma",
    "vue",
    "admin",
    "element-plus",
    "schema-form",
    "crud-table"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "types": "./dist/src/exports/components.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    },
    "./auth": {
      "types": "./dist/src/auth/index.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./composables": {
      "types": "./dist/src/composables/index.d.ts",
      "import": "./dist/composables.js",
      "require": "./dist/composables.cjs"
    },
    "./dictionary": {
      "types": "./dist/src/dictionary/index.d.ts",
      "import": "./dist/dictionary.js",
      "require": "./dist/dictionary.cjs"
    },
    "./directives": {
      "types": "./dist/src/directives/index.d.ts",
      "import": "./dist/directives.js",
      "require": "./dist/directives.cjs"
    },
    "./layout": {
      "types": "./dist/src/layout/index.d.ts",
      "import": "./dist/layout.js",
      "require": "./dist/layout.cjs"
    },
    "./permission": {
      "types": "./dist/src/permission/index.d.ts",
      "import": "./dist/permission.js",
      "require": "./dist/permission.cjs"
    },
    "./request": {
      "types": "./dist/src/request/index.d.ts",
      "import": "./dist/request.js",
      "require": "./dist/request.cjs"
    },
    "./router": {
      "types": "./dist/src/router/index.d.ts",
      "import": "./dist/router.js",
      "require": "./dist/router.cjs"
    },
    "./theme": {
      "types": "./dist/src/theme/index.d.ts",
      "import": "./dist/theme.js",
      "require": "./dist/theme.cjs"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./style.css": "./dist/core.css",
    "./theme-chalk/index.scss": "./theme-chalk/index.scss"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "theme-chalk"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && vue-tsc -p tsconfig.json --emitDeclarationOnly --outDir dist && node ../../scripts/clean-package-dist.mjs dist",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts tests"
  },
  "peerDependencies": {
    "element-plus": "^2.11.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "peerDependenciesMeta": {
    "element-plus": {
      "optional": true
    },
    "pinia": {
      "optional": true
    },
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@luma/icons": "workspace:*",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9"
  }
}
