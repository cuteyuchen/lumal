{
  "name": "@luma/icons",
  "type": "module",
  "version": "0.0.0",
  "description": "Luma independent icon registry and Vue icon components.",
  "keywords": [
    "luma",
    "vue",
    "icons",
    "iconify",
    "svg"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/src/vite/index.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./style.css": "./dist/icons.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && vue-tsc -p tsconfig.json --emitDeclarationOnly --outDir dist && node ../../scripts/clean-package-dist.mjs dist",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts tests"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@iconify/vue": {
      "optional": true
    }
  }
}
